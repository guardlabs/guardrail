{
  "name": "@guardlabs/guardrail-cli",
  "version": "0.1.3",
  "license": "MIT",
  "description": "CLI for provisioning and using Guardrail, the Guard Labs wallet-control product for agents.",
  "type": "module",
  "homepage": "https://github.com/guardlabs/guardrail",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardlabs/guardrail.git"
  },
  "bugs": {
    "url": "https://github.com/guardlabs/guardrail/issues"
  },
  "keywords": [
    "guardrail",
    "guardlabs",
    "wallet",
    "guardrails",
    "cli",
    "agents",
    "evm",
    "base"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "guardrail": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=html --coverage.include=\"src/**/*.ts\" --coverage.exclude=\"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "viem": "2.47.6"
  },
  "devDependencies": {
    "@guardlabs/guardrail-core": "workspace:*",
    "@guardlabs/guardrail-kernel": "workspace:*",
    "@types/node": "^22.13.10",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  }
}
