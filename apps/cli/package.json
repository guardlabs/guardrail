{
  "name": "@conduit/cli",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "conduit-wallet": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=html --coverage.include=\"src/**/*.ts\" --coverage.exclude=\"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@conduit/shared": "workspace:*",
    "@conduit/zerodev": "workspace:*",
    "@zerodev/sdk": "5.5.8",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "permissionless": "0.3.4",
    "tslib": "^2.8.1",
    "viem": "2.47.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  }
}
