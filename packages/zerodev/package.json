{
  "name": "@conduit/zerodev",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=html --coverage.include=\"src/**/*.ts\" --coverage.exclude=\"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@conduit/shared": "workspace:*",
    "@zerodev/passkey-validator": "5.6.0",
    "@zerodev/sdk": "5.5.8",
    "@zerodev/webauthn-key": "^5.4.2",
    "@zerodev/weighted-ecdsa-validator": "5.4.4",
    "viem": "2.47.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
