{
  "name": "@conduit/frontend",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run --environment jsdom --passWithNoTests",
    "test:coverage": "vitest run --environment jsdom --passWithNoTests --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=html --coverage.include=\"src/**/*.{ts,tsx}\" --coverage.exclude=\"src/**/*.test.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@conduit/shared": "workspace:*",
    "@conduit/zerodev": "workspace:*",
    "@zerodev/permissions": "5.6.3",
    "@zerodev/webauthn-key": "^5.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "2.47.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^3.0.9"
  }
}
